<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Antisleep AI"
            android:textColor="#66E0A3"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- AI Advice Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/ai_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Sleep Insights"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/ai_response_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading healthy sleep tips..."
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btn_get_ai_advice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh Advice"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sleep Time Predictor Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep Time Predictor"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="When do you want to wake up?"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="12dp" />

                <Button
                    android:id="@+id/btn_pick_wake_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Set Wake-up Time"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#66E0A3"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/prediction_result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pick a time to see sleep recommendations."
                    android:textColor="#66E0A3"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:textStyle="italic" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>